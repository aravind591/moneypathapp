# apps/api/.env.example
# Copy this file to .env and fill in real values. Never commit .env.

# Database — Supabase Postgres direct connection (port 5432, used for Prisma migrations)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # Never expose this on the frontend

# Auth
JWT_SECRET=a-very-long-random-secret-minimum-32-characters

# Redis (for OTP storage and BullMQ) — Upstash rediss:// URL works here
REDIS_URL=redis://localhost:6379

# SMS — stub for now (mobile OTP is deferred; codes are delivered by email).
MSG91_API_KEY=stub-msg91-key
MSG91_SENDER_ID=MNYPTH

# Email — Resend (free tier: 3,000 emails/mo). Used only when MESSAGING_MODE=live.
RESEND_API_KEY=re_your_resend_key

# Messaging mode: "dev" prints codes to the console (no external send, default);
# "live" sends real email via Resend. EMAIL_FROM must be a Resend-verified sender
# in live mode (the onboarding@resend.dev sandbox works for first tests).
MESSAGING_MODE=dev
EMAIL_FROM=MoneyPath <onboarding@resend.dev>

# Security
ALLOWED_ORIGIN=http://localhost:3000
INTERNAL_API_KEY=a-separate-long-secret-for-machine-access
NODE_ENV=development
